{
  "build": {
    "beforeBuildCommand": "rm -rf dist && mkdir -p dist && cp index.html app.js dist/ && cp -r css lib dist/",
    "beforeDevCommand": "",
    "devPath": "../",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "PXLS Editor",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      },
      "dialog": {
        "all": false,
        "save": true
      },
      "fs": {
        "all": false,
        "readFile": false,
        "writeFile": true,
        "readDir": false,
        "copyFile": false,
        "createDir": false,
        "removeDir": false,
        "removeFile": false,
        "renameFile": false,
        "exists": false,
        "scope": ["$DOWNLOAD/*", "$DESKTOP/*", "$DOCUMENT/*", "$HOME/*"]
      }
    },
    "bundle": {
      "active": true,
      "category": "Graphics and Design",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.pxls.editor",
      "longDescription": "A powerful image browser and color extraction tool powered by the Pexels API. Browse millions of high-quality photos, apply real-time filters, and extract color palettes using K-means clustering.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Pexels image browser with color extraction",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.pexels.com https://images.pexels.com; img-src 'self' https://images.pexels.com data: blob:; style-src 'self' 'unsafe-inline' https://rsms.me; font-src 'self' https://rsms.me; script-src 'self'"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "PXLS Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}
